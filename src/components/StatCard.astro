---
export interface Props {
  value: string | number;
  label: string;
  icon?: string;
}

const { value, label, icon } = Astro.props;
---

<div class="card text-center p-5">
  <div class="text-3xl font-display font-bold text-primary-600 dark:text-primary-400 mb-1">
    {value}
  </div>
  <div class="text-sm text-navy-500 dark:text-navy-400">
    {label}
  </div>
</div>
