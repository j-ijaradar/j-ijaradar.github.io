---
import { getProfile } from '../lib/data';
const profile = getProfile();
const year = new Date().getFullYear();
---

<footer class="border-t border-navy-100 dark:border-navy-800 mt-16">
  <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="text-sm text-navy-400 dark:text-navy-500">
      &copy; {year} {profile.name}
    </span>

    <div class="flex items-center gap-5">
      <a href={profile.links.github} target="_blank" rel="noopener" aria-label="GitHub" class="icon-link text-lg">
        <i class="fa-brands fa-github"></i>
      </a>
      <a href={profile.links.scholar} target="_blank" rel="noopener" aria-label="Google Scholar" class="icon-link text-lg">
        <i class="ai ai-google-scholar"></i>
      </a>
      <a href={profile.links.orcid} target="_blank" rel="noopener" aria-label="ORCID" class="icon-link text-lg">
        <i class="ai ai-orcid"></i>
      </a>
      <a href={profile.links.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="icon-link text-lg">
        <i class="fa-brands fa-linkedin"></i>
      </a>
      <a href={profile.links.researchgate} target="_blank" rel="noopener" aria-label="ResearchGate" class="icon-link text-lg">
        <i class="ai ai-researchgate"></i>
      </a>
      <a href={`mailto:${profile.email}`} aria-label="Email" class="icon-link text-lg">
        <i class="fa-solid fa-envelope"></i>
      </a>
    </div>
  </div>
</footer>
