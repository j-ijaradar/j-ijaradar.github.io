---
export interface Props {
  title: string;
  description: string;
  role: string;
  funding?: string;
  duration?: string;
  website?: string;
  status?: string;
  tags?: string[];
}

const { title, description, role, funding, duration, website, status, tags = [] } = Astro.props;
---

<div class="card">
  <div class="flex items-start justify-between mb-3">
    <h3 class="font-display text-lg font-bold text-navy-900 dark:text-navy-50">{title}</h3>
    {status && (
      <span class:list={[
        'badge',
        status === 'active' ? 'bg-green-50 text-green-700 dark:bg-green-950 dark:text-green-300' : ''
      ]}>
        {status === 'active' ? 'Active' : status}
      </span>
    )}
  </div>
  <p class="text-navy-600 dark:text-navy-300 text-sm mb-4 leading-relaxed">{description}</p>

  <div class="space-y-2 text-sm">
    <div class="flex items-start gap-2">
      <span class="text-navy-400 dark:text-navy-500 shrink-0 font-medium">Role:</span>
      <span class="text-navy-700 dark:text-navy-300">{role}</span>
    </div>
    {funding && (
      <div class="flex items-start gap-2">
        <span class="text-navy-400 dark:text-navy-500 shrink-0 font-medium">Funding:</span>
        <span class="text-navy-700 dark:text-navy-300">{funding}</span>
      </div>
    )}
    {duration && (
      <div class="flex items-start gap-2">
        <span class="text-navy-400 dark:text-navy-500 shrink-0 font-medium">Duration:</span>
        <span class="text-navy-700 dark:text-navy-300">{duration}</span>
      </div>
    )}
  </div>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-4">
      {tags.map((tag: string) => (
        <span class="badge">{tag}</span>
      ))}
    </div>
  )}

  {website && !website.startsWith('[') && (
    <div class="mt-4 pt-4 border-t border-navy-100 dark:border-navy-800">
      <a href={website} class="btn-ghost text-primary-600 dark:text-primary-400" target="_blank" rel="noopener">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        Project Website
      </a>
    </div>
  )}
</div>
