---
export interface Props {
  title: string;
  date: string;
  category: string;
  tags?: string[];
  summary: string;
  slug: string;
}

const { title, date, category, tags = [], summary, slug } = Astro.props;
---

<a href={`/research-notes/${slug}/`} class="card block group">
  <div class="flex items-center gap-2 mb-2">
    <span class="badge">{category}</span>
    <span class="text-xs text-navy-400 dark:text-navy-500">{date}</span>
  </div>
  <h3 class="font-display font-semibold text-navy-900 dark:text-navy-50 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-2">
    {title}
  </h3>
  <p class="text-sm text-navy-500 dark:text-navy-400 leading-relaxed line-clamp-2">
    {summary}
  </p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {tags.map((tag: string) => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-navy-100 dark:bg-navy-800 text-navy-500 dark:text-navy-400">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
