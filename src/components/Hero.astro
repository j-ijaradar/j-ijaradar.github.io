---
import { getProfile } from '../lib/data';
const profile = getProfile();
---

<section class="pt-28 pb-14 px-6 bg-gradient-to-br from-primary-50/70 via-white to-accent-50/40 dark:from-primary-950/30 dark:via-navy-950 dark:to-accent-900/20">
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 sm:gap-12">

      <!-- Profile photo -->
      <div class="shrink-0">
        <div class="w-36 h-36 sm:w-40 sm:h-40 rounded-full ring-2 ring-navy-200 dark:ring-navy-700 overflow-hidden bg-navy-100 dark:bg-navy-800 flex items-center justify-center">
          <img
            src={profile.photo}
            alt={profile.name}
            class="w-full h-full object-cover"
            onerror="this.style.display='none';document.getElementById('photo-fallback').style.display='flex'"
          />
          <span id="photo-fallback" class="text-3xl font-semibold text-navy-400 dark:text-navy-500" style="display:none">JI</span>
        </div>
      </div>

      <!-- Text content -->
      <div class="text-center sm:text-left">
        <h1 class="text-3xl sm:text-4xl font-semibold text-navy-900 dark:text-navy-50 mb-1">
          {profile.name}
        </h1>
        <p class="text-base text-primary-700 dark:text-primary-400 mb-1">
          {profile.title}
        </p>
        <p class="text-sm text-navy-500 dark:text-navy-400 mb-5">
          {profile.position} · {profile.institution}
        </p>

        <!-- Social icon links -->
        <div class="flex flex-wrap justify-center sm:justify-start items-center gap-4 mb-5">
          <a href={profile.links.github} target="_blank" rel="noopener" aria-label="GitHub" class="icon-link text-xl">
            <i class="fa-brands fa-github"></i>
          </a>
          <a href={profile.links.scholar} target="_blank" rel="noopener" aria-label="Google Scholar" class="icon-link text-xl">
            <i class="ai ai-google-scholar"></i>
          </a>
          <a href={profile.links.orcid} target="_blank" rel="noopener" aria-label="ORCID" class="icon-link text-xl">
            <i class="ai ai-orcid"></i>
          </a>
          <a href={profile.links.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="icon-link text-xl">
            <i class="fa-brands fa-linkedin"></i>
          </a>
          <a href={profile.links.researchgate} target="_blank" rel="noopener" aria-label="ResearchGate" class="icon-link text-xl">
            <i class="ai ai-researchgate"></i>
          </a>
          <a href={`mailto:${profile.email}`} aria-label="Email" class="icon-link text-xl">
            <i class="fa-solid fa-envelope"></i>
          </a>
        </div>

        <!-- CV button -->
        <a href={profile.cv_pdf} class="btn-primary text-sm" target="_blank">
          <i class="fa-solid fa-file-pdf text-sm"></i>
          Download CV
        </a>
      </div>

    </div>
  </div>
</section>
