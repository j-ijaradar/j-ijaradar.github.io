---
export interface Props {
  title: string;
  subtitle?: string;
  href?: string;
  linkText?: string;
}

const { title, subtitle, href, linkText = 'View All' } = Astro.props;
---

<div class="flex items-end justify-between mb-8">
  <div>
    <h2 class="section-title">{title}</h2>
    {subtitle && <p class="section-subtitle mb-0">{subtitle}</p>}
  </div>
  {href && (
    <a href={href} class="btn-ghost text-primary-600 dark:text-primary-400 shrink-0">
      {linkText}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  )}
</div>
