---
export interface Props {
  id: string;
  title: string;
  authors: string;
  venue: string;
  year: number;
  type?: string;
  topics?: string[];
  doi?: string;
  pdf?: string;
  code?: string;
  bibtex?: string;
  featured?: boolean;
}

const { id, title, authors, venue, year, type, topics = [], doi, pdf, code, bibtex, featured } = Astro.props;
---

<div class:list={['card', featured && 'ring-1 ring-primary-200 dark:ring-primary-800']}>
  <div class="flex items-start gap-3 mb-2">
    {type && (
      <span class:list={[
        'badge shrink-0 mt-1',
        type === 'journal' ? 'bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300' :
        'bg-purple-50 text-purple-700 dark:bg-purple-950 dark:text-purple-300'
      ]}>
        {type === 'journal' ? 'Journal' : 'Conference'}
      </span>
    )}
    <div>
      <h3 class="font-display font-semibold text-navy-900 dark:text-navy-50 leading-snug">{title}</h3>
      <p class="text-sm text-navy-500 dark:text-navy-400 mt-1">{authors}</p>
      <p class="text-sm text-navy-400 dark:text-navy-500 italic">{venue}, {year}</p>
    </div>
  </div>

  {topics.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {topics.map((topic: string) => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-navy-100 dark:bg-navy-800 text-navy-500 dark:text-navy-400">
          {topic}
        </span>
      ))}
    </div>
  )}

  <div class="flex flex-wrap gap-2 mt-4 pt-3 border-t border-navy-100 dark:border-navy-800">
    {doi && !doi.startsWith('[') && (
      <a href={doi} class="btn-ghost text-xs" target="_blank" rel="noopener">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        DOI
      </a>
    )}
    {pdf && !pdf.startsWith('[') && (
      <a href={pdf} class="btn-ghost text-xs" target="_blank" rel="noopener">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        PDF
      </a>
    )}
    {code && !code.startsWith('[') && (
      <a href={code} class="btn-ghost text-xs" target="_blank" rel="noopener">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        Code
      </a>
    )}
    {bibtex && (
      <button class="btn-ghost text-xs bibtex-btn" data-bibtex={encodeURIComponent(bibtex)} data-id={id}>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
        BibTeX
      </button>
    )}
  </div>
</div>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;
    const btn = target.closest('.bibtex-btn');
    if (!btn) return;
    const raw = btn.getAttribute('data-bibtex');
    if (raw) {
      const bibtex = decodeURIComponent(raw);
      navigator.clipboard.writeText(bibtex).then(() => {
        const originalHTML = btn.innerHTML;
        btn.innerHTML = 'Copied!';
        setTimeout(() => { btn.innerHTML = originalHTML; }, 2000);
      });
    }
  });
</script>
