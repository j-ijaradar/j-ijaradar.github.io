---
export interface Props {
  id: string;
  title: string;
  authors: string;
  venue: string;
  year: number;
  type?: string;
  topics?: string[];
  doi?: string;
  pdf?: string;
  code?: string;
  bibtex?: string;
  featured?: boolean;
}

const { id, title, authors, venue, year, type, topics = [], doi, pdf, code, bibtex } = Astro.props;

const typeLabel = type === 'journal' ? 'Journal' : type === 'conference' ? 'Conf.' : type ?? '';
const typeColor = type === 'journal'
  ? 'text-primary-700 dark:text-primary-400'
  : 'text-accent-700 dark:text-accent-400';
---

<div class="py-5 border-b border-navy-100 dark:border-navy-800 last:border-0">
  <div class="flex gap-4">
    <!-- Year + type column -->
    <div class="shrink-0 w-16 text-right pt-0.5">
      <span class="text-sm text-navy-400 dark:text-navy-500">{year}</span>
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-navy-900 dark:text-navy-50 leading-snug mb-1 text-base">
        {title}
      </h3>
      <p class="text-sm text-navy-600 dark:text-navy-400 mb-0.5">{authors}</p>
      <p class="text-sm text-navy-500 dark:text-navy-500 italic mb-2">
        {typeLabel && <span class={`not-italic font-medium mr-1 ${typeColor}`}>{typeLabel} ·</span>}
        {venue}
      </p>

      {topics.length > 0 && (
        <div class="flex flex-wrap gap-1 mb-3">
          {topics.map((topic: string) => (
            <span class="text-xs px-1.5 py-0.5 rounded bg-navy-100 dark:bg-navy-800 text-navy-500 dark:text-navy-400">
              {topic}
            </span>
          ))}
        </div>
      )}

      <!-- Links -->
      <div class="flex flex-wrap gap-4">
        {doi && !doi.startsWith('[') && (
          <a href={doi} class="btn-ghost text-xs" target="_blank" rel="noopener">
            <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
            DOI
          </a>
        )}
        {pdf && !pdf.startsWith('[') && (
          <a href={pdf} class="btn-ghost text-xs" target="_blank" rel="noopener">
            <i class="fa-solid fa-file-pdf text-xs"></i>
            PDF
          </a>
        )}
        {code && !code.startsWith('[') && (
          <a href={code} class="btn-ghost text-xs" target="_blank" rel="noopener">
            <i class="fa-brands fa-github text-xs"></i>
            Code
          </a>
        )}
        {bibtex && (
          <button class="btn-ghost text-xs bibtex-btn" data-bibtex={encodeURIComponent(bibtex)} data-id={id}>
            <i class="fa-solid fa-quote-right text-xs"></i>
            Cite
          </button>
        )}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;
    const btn = target.closest('.bibtex-btn');
    if (!btn) return;
    const raw = btn.getAttribute('data-bibtex');
    if (raw) {
      const bibtex = decodeURIComponent(raw);
      navigator.clipboard.writeText(bibtex).then(() => {
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-check text-xs"></i> Copied!';
        setTimeout(() => { btn.innerHTML = originalHTML; }, 2000);
      });
    }
  });
</script>
