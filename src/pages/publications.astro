---
import PageLayout from '../layouts/PageLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getPublications } from '../lib/data';

const publications = getPublications();
const allPubs = publications.publications;

// Group by year
const pubsByYear: Record<number, any[]> = {};
allPubs.forEach((pub: any) => {
  if (!pubsByYear[pub.year]) pubsByYear[pub.year] = [];
  pubsByYear[pub.year].push(pub);
});
const years = Object.keys(pubsByYear).map(Number).sort((a, b) => b - a);

// Collect all topics
const allTopics = [...new Set(allPubs.flatMap((p: any) => p.topics || []))].sort();
---

<PageLayout
  title="Publications"
  description="Publications by Jyotirmaya Ijaradar in traffic data science and AI for mobility."
  pageTitle="Publications"
  pageSubtitle="Journal articles, conference papers, and preprints"
>

    <!-- Topic Filters -->
    {allTopics.length > 0 && (
      <div class="mb-10">
        <p class="text-xs font-medium text-navy-400 dark:text-navy-500 uppercase tracking-wider mb-3">Filter by topic</p>
        <div class="flex flex-wrap gap-2" id="topic-filters">
          <button class="text-xs px-3 py-1 rounded border border-primary-600 bg-primary-600 text-white cursor-pointer transition-colors" data-topic="all">All</button>
          {allTopics.map((topic: string) => (
            <button class="text-xs px-3 py-1 rounded border border-navy-200 dark:border-navy-700 text-navy-500 dark:text-navy-400 cursor-pointer hover:border-primary-500 transition-colors" data-topic={topic}>
              {topic}
            </button>
          ))}
        </div>
      </div>
    )}

    <!-- Publications by Year -->
    {years.map(year => (
      <section class="mb-8" data-year={year}>
        <h2 class="text-lg font-semibold text-navy-700 dark:text-navy-300 mb-0 flex items-center gap-3">
          <span>{year}</span>
          <span class="h-px flex-1 bg-navy-100 dark:bg-navy-800"></span>
        </h2>
        <div class="pub-list">
          {pubsByYear[year].map((pub: any) => (
            <div data-topics={JSON.stringify(pub.topics || [])}>
              <PublicationCard
                id={pub.id}
                title={pub.title}
                authors={pub.authors}
                venue={pub.venue}
                year={pub.year}
                type={pub.type}
                topics={pub.topics}
                doi={pub.doi}
                pdf={pub.pdf}
                code={pub.code}
                bibtex={pub.bibtex}
                featured={pub.featured}
              />
            </div>
          ))}
        </div>
      </section>
    ))}


  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('#topic-filters button');
      const pubItems = document.querySelectorAll('[data-topics]');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const topic = btn.getAttribute('data-topic');

          filterBtns.forEach(b => {
            b.classList.remove('bg-primary-600', 'border-primary-600', 'text-white');
            b.classList.add('border-navy-200', 'dark:border-navy-700', 'text-navy-500', 'dark:text-navy-400');
          });
          btn.classList.add('bg-primary-600', 'border-primary-600', 'text-white');
          btn.classList.remove('border-navy-200', 'dark:border-navy-700', 'text-navy-500', 'dark:text-navy-400');

          pubItems.forEach(item => {
            if (topic === 'all') {
              (item as HTMLElement).style.display = '';
            } else {
              const topics = JSON.parse(item.getAttribute('data-topics') || '[]');
              (item as HTMLElement).style.display = topics.includes(topic) ? '' : 'none';
            }
          });
        });
      });
    });
  </script>

</PageLayout>
