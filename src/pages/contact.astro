---
import PageLayout from '../layouts/PageLayout.astro';
import { getProfile } from '../lib/data';

const profile = getProfile();
const links = profile.links || {};
---

<PageLayout title="Contact" description="Get in touch with Jyotirmaya Ijaradar">
  <div class="page-container">
    <div class="page-header">
      <h1 class="text-4xl font-bold text-slate-900 dark:text-white">Contact</h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 max-w-2xl">
        Feel free to reach out for research collaborations, questions about my work, or academic inquiries.
      </p>
    </div>

    <div class="mt-12 grid lg:grid-cols-2 gap-12">
      <!-- Contact Information -->
      <div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Get in Touch</h2>

        <div class="space-y-6">
          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white">Email</h3>
              <a href={`mailto:${links.email || 'jyotirmaya.ijaradar@example.com'}`} class="text-primary-600 dark:text-primary-400 hover:underline">
                {links.email || 'jyotirmaya.ijaradar@example.com'}
              </a>
            </div>
          </div>

          <!-- Office -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white">Office</h3>
              <p class="text-slate-600 dark:text-slate-300">[Office address to be added]</p>
              <p class="text-slate-500 dark:text-slate-400 text-sm">[Institution name]</p>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white">Location</h3>
              <p class="text-slate-600 dark:text-slate-300">Dresden, Germany</p>
            </div>
          </div>
        </div>

        <!-- Academic Profiles -->
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6 mt-12">Academic Profiles</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {links.github && (
            <a href={links.github} target="_blank" rel="noopener noreferrer" class="card p-4 flex items-center gap-3 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <svg class="w-6 h-6 text-slate-700 dark:text-slate-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              <div>
                <div class="font-medium text-slate-900 dark:text-white">GitHub</div>
                <div class="text-sm text-slate-500 dark:text-slate-400">Code & Projects</div>
              </div>
            </a>
          )}

          {links.google_scholar && (
            <a href={links.google_scholar} target="_blank" rel="noopener noreferrer" class="card p-4 flex items-center gap-3 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <svg class="w-6 h-6 text-slate-700 dark:text-slate-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 24a7 7 0 110-14 7 7 0 010 14zm0-24L0 9.5l4.838 3.94A8 8 0 0112 9a8 8 0 017.162 4.44L24 9.5z"/></svg>
              <div>
                <div class="font-medium text-slate-900 dark:text-white">Google Scholar</div>
                <div class="text-sm text-slate-500 dark:text-slate-400">Publications</div>
              </div>
            </a>
          )}

          {links.orcid && (
            <a href={links.orcid} target="_blank" rel="noopener noreferrer" class="card p-4 flex items-center gap-3 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <svg class="w-6 h-6 text-slate-700 dark:text-slate-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-1.847-1.303-3.722-3.853-3.722h-2.466z"/></svg>
              <div>
                <div class="font-medium text-slate-900 dark:text-white">ORCID</div>
                <div class="text-sm text-slate-500 dark:text-slate-400">Researcher ID</div>
              </div>
            </a>
          )}

          {links.linkedin && (
            <a href={links.linkedin} target="_blank" rel="noopener noreferrer" class="card p-4 flex items-center gap-3 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <svg class="w-6 h-6 text-slate-700 dark:text-slate-300" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <div>
                <div class="font-medium text-slate-900 dark:text-white">LinkedIn</div>
                <div class="text-sm text-slate-500 dark:text-slate-400">Professional Network</div>
              </div>
            </a>
          )}

          {links.researchgate && (
            <a href={links.researchgate} target="_blank" rel="noopener noreferrer" class="card p-4 flex items-center gap-3 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <svg class="w-6 h-6 text-slate-700 dark:text-slate-300" fill="currentColor" viewBox="0 0 24 24"><path d="M19.586 0c-2.361 0-4.277 1.916-4.277 4.277V12c0 2.361 1.916 4.277 4.277 4.277S23.863 14.361 23.863 12V4.277C23.863 1.916 21.947 0 19.586 0zM4.277 7.863C1.916 7.863 0 9.779 0 12.14s1.916 4.277 4.277 4.277 4.277-1.916 4.277-4.277S6.638 7.863 4.277 7.863z"/></svg>
              <div>
                <div class="font-medium text-slate-900 dark:text-white">ResearchGate</div>
                <div class="text-sm text-slate-500 dark:text-slate-400">Research Network</div>
              </div>
            </a>
          )}
        </div>
      </div>

      <!-- Contact Form Placeholder / Additional Info -->
      <div>
        <div class="card p-8">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Interested in Collaboration?</h2>
          <p class="text-slate-600 dark:text-slate-300 mb-6">
            I am open to research collaborations, supervision inquiries, and academic discussions.
            Please reach out via email for the fastest response.
          </p>

          <div class="space-y-4">
            <div class="p-4 rounded-lg bg-primary-50 dark:bg-primary-900/20 border border-primary-200 dark:border-primary-800">
              <h3 class="font-semibold text-primary-900 dark:text-primary-300 mb-1">Research Collaborations</h3>
              <p class="text-sm text-primary-700 dark:text-primary-400">
                Interested in traffic data science, AI for mobility, or spatiotemporal modelling? Let's discuss potential collaborations.
              </p>
            </div>

            <div class="p-4 rounded-lg bg-accent-50 dark:bg-accent-900/20 border border-accent-200 dark:border-accent-800">
              <h3 class="font-semibold text-accent-900 dark:text-accent-300 mb-1">Student Supervision</h3>
              <p class="text-sm text-accent-700 dark:text-accent-400">
                Looking for a thesis topic or research project? Check my <a href="/teaching-supervision" class="underline">open topics</a> page.
              </p>
            </div>

            <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
              <h3 class="font-semibold text-slate-900 dark:text-slate-200 mb-1">General Inquiries</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                For any other questions about my research, software tools, or academic activities, feel free to send me an email.
              </p>
            </div>
          </div>
        </div>

        <div class="mt-6 card p-6">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-3">Response Time</h3>
          <p class="text-slate-600 dark:text-slate-300 text-sm">
            I typically respond to emails within a few working days. For urgent matters, please mention it in the subject line.
          </p>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
