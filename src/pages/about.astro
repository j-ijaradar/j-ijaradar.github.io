---
import PageLayout from '../layouts/PageLayout.astro';
import { getProfile, getSkills } from '../lib/data';

const profile = getProfile();
const skills = getSkills();
---

<PageLayout title="About" description="Learn about Jyotirmaya Ijaradar — researcher in traffic data science and AI for mobility.">

  <div class="page-header">
    <div class="max-w-6xl mx-auto">
      <h1 class="section-title text-4xl">About Me</h1>
      <p class="section-subtitle">Researcher, developer, and lifelong learner</p>
    </div>
  </div>

  <div class="page-container">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-10">
        <!-- Bio -->
        <section>
          <h2 class="font-display text-xl font-bold text-navy-900 dark:text-navy-50 mb-4">Professional Biography</h2>
          <div class="prose-custom">
            <p>{profile.bio_long}</p>
          </div>
        </section>

        <!-- Current Position -->
        <section>
          <h2 class="font-display text-xl font-bold text-navy-900 dark:text-navy-50 mb-4">Current Position</h2>
          <div class="card">
            <p class="font-semibold text-navy-900 dark:text-navy-50">{profile.position}</p>
            <p class="text-navy-600 dark:text-navy-300">{profile.institution}</p>
            <p class="text-sm text-navy-400 dark:text-navy-500">{profile.department}</p>
          </div>
        </section>

        <!-- Education -->
        <section>
          <h2 class="font-display text-xl font-bold text-navy-900 dark:text-navy-50 mb-4">Academic Background</h2>
          <div class="space-y-4">
            {profile.education.map((edu: any) => (
              <div class="card">
                <div class="flex items-start justify-between">
                  <div>
                    <p class="font-semibold text-navy-900 dark:text-navy-50">{edu.degree}</p>
                    <p class="text-navy-600 dark:text-navy-300">{edu.field}</p>
                    <p class="text-sm text-navy-400 dark:text-navy-500">{edu.institution}</p>
                  </div>
                  <span class="badge shrink-0">{edu.year}</span>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Research Interests -->
        <section>
          <h2 class="font-display text-xl font-bold text-navy-900 dark:text-navy-50 mb-4">Research Interests</h2>
          <div class="flex flex-wrap gap-2">
            {profile.research_interests.map((interest: string) => (
              <span class="badge text-sm">{interest}</span>
            ))}
          </div>
        </section>

        <!-- Personal Note -->
        <section>
          <h2 class="font-display text-xl font-bold text-navy-900 dark:text-navy-50 mb-4">Beyond Research</h2>
          <div class="prose-custom">
            <p>{profile.personal_note}</p>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Profile card -->
        <div class="card text-center">
          <div class="w-28 h-28 rounded-xl bg-gradient-to-br from-primary-400 to-accent-500 p-0.5 mx-auto mb-4">
            <div class="w-full h-full rounded-xl bg-navy-200 dark:bg-navy-700 flex items-center justify-center">
              <span class="text-3xl font-display font-bold text-navy-400 dark:text-navy-500">JI</span>
            </div>
          </div>
          <h3 class="font-display font-bold text-navy-900 dark:text-navy-50">{profile.name}</h3>
          <p class="text-sm text-navy-500 dark:text-navy-400 mt-1">{profile.position}</p>
          <p class="text-sm text-navy-400 dark:text-navy-500">{profile.institution}</p>
          <div class="flex justify-center gap-2 mt-4">
            <a href={profile.links.github} class="p-2 rounded-lg text-navy-400 hover:text-navy-900 dark:hover:text-navy-100 hover:bg-navy-100 dark:hover:bg-navy-800 transition-colors" target="_blank" rel="noopener" aria-label="GitHub">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href={profile.links.scholar} class="p-2 rounded-lg text-navy-400 hover:text-navy-900 dark:hover:text-navy-100 hover:bg-navy-100 dark:hover:bg-navy-800 transition-colors" target="_blank" rel="noopener" aria-label="Scholar">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
            </a>
            <a href={profile.links.linkedin} class="p-2 rounded-lg text-navy-400 hover:text-navy-900 dark:hover:text-navy-100 hover:bg-navy-100 dark:hover:bg-navy-800 transition-colors" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>

        <!-- Technical Skills -->
        <div class="card">
          <h3 class="font-display font-bold text-navy-900 dark:text-navy-50 mb-4">Technical Skills</h3>
          <div class="space-y-4">
            {skills.technical.map((cat: any) => (
              <div>
                <h4 class="text-xs font-semibold text-navy-400 dark:text-navy-500 uppercase tracking-wider mb-2">{cat.category}</h4>
                <div class="flex flex-wrap gap-1.5">
                  {cat.skills.map((s: any) => (
                    <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-100 dark:bg-navy-800 text-navy-600 dark:text-navy-400">
                      {s.name}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Languages -->
        <div class="card">
          <h3 class="font-display font-bold text-navy-900 dark:text-navy-50 mb-4">Languages</h3>
          <div class="space-y-2">
            {skills.languages.map((lang: any) => (
              <div class="flex justify-between text-sm">
                <span class="text-navy-700 dark:text-navy-300">{lang.name}</span>
                <span class="text-navy-400 dark:text-navy-500">{lang.level}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

</PageLayout>
