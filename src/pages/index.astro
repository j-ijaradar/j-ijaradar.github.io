---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getProfile, getSoftware, getPublications, getProjects, getOpenTopics, getTeaching, getNews } from '../lib/data';

const profile    = getProfile();
const software   = getSoftware();
const pubs       = getPublications();
const projects   = getProjects();
const topics     = getOpenTopics();
const teaching   = getTeaching();
const newsData   = getNews();

const featuredPubs     = pubs.publications.filter((p: any) => p.featured).slice(0, 3);
const activeProjects   = projects.projects.filter((p: any) => p.status === 'active').slice(0, 3);
const availableTopics  = [
  ...topics.thesis_topics.filter((t: any) => t.status === 'available'),
  ...topics.research_assistant_topics.filter((t: any) => t.status === 'available'),
].slice(0, 3);

const latestPubs = [...pubs.publications].sort((a: any, b: any) => b.year - a.year).slice(0, 2);

const totalStudents =
  (teaching.supervision?.master_theses?.length ?? 0) +
  (teaching.supervision?.bachelor_theses?.length ?? 0) +
  (teaching.supervision?.student_projects?.length ?? 0);

const homeStats = [
  { value: pubs.publications.length,      label: 'Publications' },
  { value: projects.projects.length,      label: 'Research Projects' },
  { value: software.software.filter((s: any) => s.status !== 'Planned').length, label: 'Software Tools' },
  { value: totalStudents || '—',          label: 'Students Supervised' },
];

// Unified news feed items
interface FeedItem { type: string; date: string; title: string; description: string; link: string; }
const feedItems: FeedItem[] = [
  ...latestPubs.map((p: any): FeedItem => ({
    type: 'publication',
    date: String(p.year),
    title: p.title,
    description: `${p.venue}`,
    link: p.doi && !p.doi.startsWith('[') ? p.doi : (p.pdf && !p.pdf.startsWith('[') ? p.pdf : ''),
  })),
  ...newsData.news.map((n: any): FeedItem => ({
    type: n.type,
    date: n.date,
    title: n.title,
    description: n.description || '',
    link: n.link || '',
  })),
  ...availableTopics.map((t: any): FeedItem => ({
    type: 'topic',
    date: '',
    title: t.title,
    description: t.type ?? '',
    link: '/teaching-supervision/',
  })),
];

const badgeClass: Record<string, string> = {
  publication: 'bg-primary-100 text-primary-800 dark:bg-primary-950 dark:text-primary-200',
  event:       'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200',
  award:       'bg-accent-100 text-accent-800 dark:bg-accent-900 dark:text-accent-200',
  update:      'bg-navy-100 text-navy-700 dark:bg-navy-800 dark:text-navy-300',
  talk:        'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200',
  topic:       'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200',
};
const badgeLabel: Record<string, string> = {
  publication: 'Paper', event: 'Event', award: 'Award', update: 'Update', talk: 'Talk', topic: 'Open Topic',
};
---

<PageLayout title="Home" description="Personal academic website of Jyotirmaya Ijaradar — Researcher in Traffic Data Science & AI for Mobility.">

  <!-- Hero -->
  <Hero />

  <div class="max-w-4xl mx-auto px-6 pb-20 space-y-14">

    <!-- Stats Bar -->
    <StatsBar stats={homeStats} />

    <!-- About -->
    <section>
      <h2 class="section-heading">About</h2>
      <p class="text-navy-600 dark:text-navy-400 leading-relaxed mb-5 max-w-2xl">
        {profile.bio_short}
      </p>
      <div class="flex flex-wrap gap-2">
        {profile.research_interests.map((interest: string) => (
          <span class="text-sm px-3 py-1 rounded-full border border-primary-200 dark:border-primary-800 bg-primary-50 dark:bg-primary-950 text-primary-800 dark:text-primary-200">
            {interest}
          </span>
        ))}
      </div>
    </section>

    <!-- News & Updates -->
    <section>
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="section-heading mb-0">News & Updates</h2>
        <div class="flex gap-2 flex-wrap" id="feed-filters">
          <button class="text-xs px-3 py-1 rounded border border-navy-700 bg-navy-800 text-white dark:border-navy-200 dark:bg-navy-100 dark:text-navy-900 transition-colors" data-filter="all">All</button>
          <button class="text-xs px-3 py-1 rounded border border-navy-200 dark:border-navy-700 text-navy-500 dark:text-navy-400 hover:border-primary-500 transition-colors" data-filter="publication">Papers</button>
          <button class="text-xs px-3 py-1 rounded border border-navy-200 dark:border-navy-700 text-navy-500 dark:text-navy-400 hover:border-amber-500 transition-colors" data-filter="event">Events</button>
          <button class="text-xs px-3 py-1 rounded border border-navy-200 dark:border-navy-700 text-navy-500 dark:text-navy-400 hover:border-blue-500 transition-colors" data-filter="topic">Open Topics</button>
        </div>
      </div>

      <ul class="space-y-3" id="feed-list">
        {feedItems.map((item) => (
          <li class="feed-item flex items-start gap-3 py-3 border-b border-navy-100 dark:border-navy-800 last:border-0" data-type={item.type}>
            <span class={`text-xs px-2 py-0.5 rounded font-medium shrink-0 mt-0.5 ${badgeClass[item.type] ?? badgeClass.update}`}>
              {badgeLabel[item.type] ?? item.type}
            </span>
            <div class="flex-1 min-w-0">
              {item.link
                ? <a href={item.link} class="text-sm font-medium text-navy-800 dark:text-navy-200 hover:text-primary-700 dark:hover:text-primary-400 hover:underline" target="_blank" rel="noopener">{item.title}</a>
                : <span class="text-sm font-medium text-navy-800 dark:text-navy-200">{item.title}</span>
              }
              {item.description && <p class="text-xs text-navy-500 dark:text-navy-400 mt-0.5">{item.description}</p>}
            </div>
            {item.date && <span class="text-xs text-navy-400 dark:text-navy-500 shrink-0 tabular-nums">{item.date}</span>}
          </li>
        ))}
      </ul>
    </section>

    <!-- Featured Projects -->
    {activeProjects.length > 0 && (
      <section>
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="section-heading mb-0">Active Projects</h2>
          <a href="/projects/" class="text-sm text-primary-700 dark:text-primary-400 hover:underline">All projects →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {activeProjects.slice(0,2).map((proj: any) => (
            <div class="card">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-semibold text-navy-900 dark:text-navy-50 text-sm">{proj.title}</h3>
                <span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-800 dark:bg-green-950 dark:text-green-300 shrink-0">Active</span>
              </div>
              <p class="text-xs text-navy-500 dark:text-navy-400 mb-2">{proj.role}</p>
              {proj.tags?.length > 0 && (
                <div class="flex flex-wrap gap-1">
                  {proj.tags.map((t: string) => <span class="badge">{t}</span>)}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Selected Publications -->
    <section>
      <div class="flex items-baseline justify-between mb-2">
        <h2 class="section-heading mb-0">Selected Publications</h2>
        <a href="/publications/" class="text-sm text-primary-700 dark:text-primary-400 hover:underline">All publications →</a>
      </div>
      <div>
        {featuredPubs.map((pub: any) => (
          <PublicationCard
            id={pub.id}
            title={pub.title}
            authors={pub.authors}
            venue={pub.venue}
            year={pub.year}
            type={pub.type}
            topics={pub.topics}
            doi={pub.doi}
            pdf={pub.pdf}
            code={pub.code}
            bibtex={pub.bibtex}
            featured={pub.featured}
          />
        ))}
      </div>
    </section>

  </div>

</PageLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('#feed-filters button');
    const items = document.querySelectorAll('.feed-item');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        btns.forEach(b => {
          b.classList.remove('bg-navy-800', 'text-white', 'border-navy-700',
                             'dark:bg-navy-100', 'dark:text-navy-900', 'dark:border-navy-200');
          b.classList.add('border-navy-200', 'dark:border-navy-700', 'text-navy-500', 'dark:text-navy-400');
        });
        btn.classList.remove('border-navy-200', 'dark:border-navy-700', 'text-navy-500', 'dark:text-navy-400');
        btn.classList.add('bg-navy-800', 'text-white', 'border-navy-700',
                          'dark:bg-navy-100', 'dark:text-navy-900', 'dark:border-navy-200');

        items.forEach(item => {
          const type = item.getAttribute('data-type') ?? '';
          const visible = filter === 'all' || type === filter ||
            (filter === 'event' && ['event', 'award', 'talk', 'update'].includes(type));
          (item as HTMLElement).style.display = visible ? '' : 'none';
        });
      });
    });
  });
</script>
