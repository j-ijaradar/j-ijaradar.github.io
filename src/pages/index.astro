---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getProfile, getSoftware, getPublications } from '../lib/data';

const profile = getProfile();
const software = getSoftware();
const publications = getPublications();

const featuredSoftware = software.software.filter((s: any) => s.featured).slice(0, 3);
const featuredPubs = publications.publications.filter((p: any) => p.featured).slice(0, 3);
---

<PageLayout title="Home" description="Personal academic website of Jyotirmaya Ijaradar — Researcher in Traffic Data Science & AI for Mobility.">

  <!-- Hero -->
  <Hero />

  <div class="max-w-4xl mx-auto px-6 pb-20 space-y-16">

    <!-- About -->
    <section>
      <h2 class="section-title">About</h2>
      <p class="text-navy-600 dark:text-navy-400 leading-relaxed mb-5 max-w-2xl">
        {profile.bio_short}
      </p>
      <div class="flex flex-wrap gap-2">
        {profile.research_interests.map((interest: string) => (
          <span class="text-sm px-3 py-1 rounded-full border border-navy-200 dark:border-navy-700 text-navy-600 dark:text-navy-400">
            {interest}
          </span>
        ))}
      </div>
    </section>

    <!-- News -->
    <section>
      <h2 class="section-title">News</h2>
      <ul class="space-y-3 text-sm text-navy-600 dark:text-navy-400">
        <li class="flex gap-3">
          <span class="shrink-0 text-navy-400 dark:text-navy-500 tabular-nums">2025-01</span>
          <span>[Sample] Starting new research project on foundation models for traffic data.</span>
        </li>
        <li class="flex gap-3">
          <span class="shrink-0 text-navy-400 dark:text-navy-500 tabular-nums">2025-01</span>
          <span>[Sample] Paper accepted at [Conference Name].</span>
        </li>
        <li class="flex gap-3">
          <span class="shrink-0 text-navy-400 dark:text-navy-500 tabular-nums">2024-12</span>
          <span>[Sample] Presented research at TRB Annual Meeting, Washington D.C.</span>
        </li>
        <li class="flex gap-3">
          <span class="shrink-0 text-navy-400 dark:text-navy-500 tabular-nums">2024-11</span>
          <span>[Sample] Released TrafficInsight360 v1.0 on GitHub.</span>
        </li>
      </ul>
    </section>

    <!-- Selected Publications -->
    <section>
      <div class="flex items-baseline justify-between mb-2">
        <h2 class="section-title">Selected Publications</h2>
        <a href="/publications/" class="text-sm text-primary-700 dark:text-primary-400 hover:underline">
          All publications →
        </a>
      </div>
      <div>
        {featuredPubs.map((pub: any) => (
          <PublicationCard
            id={pub.id}
            title={pub.title}
            authors={pub.authors}
            venue={pub.venue}
            year={pub.year}
            type={pub.type}
            topics={pub.topics}
            doi={pub.doi}
            pdf={pub.pdf}
            code={pub.code}
            bibtex={pub.bibtex}
            featured={pub.featured}
          />
        ))}
      </div>
    </section>

    <!-- Software -->
    <section>
      <h2 class="section-title">Software</h2>
      <div class="space-y-4">
        {featuredSoftware.map((sw: any) => (
          <div class="flex items-start justify-between gap-4 py-3 border-b border-navy-100 dark:border-navy-800 last:border-0">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="font-medium text-navy-900 dark:text-navy-50 text-sm">{sw.name}</span>
                <span class="text-xs px-1.5 py-0.5 rounded bg-navy-100 dark:bg-navy-800 text-navy-500 dark:text-navy-400">
                  {sw.status}
                </span>
              </div>
              <p class="text-sm text-navy-500 dark:text-navy-400">{sw.description}</p>
              <div class="flex gap-1 mt-1 flex-wrap">
                {sw.tech_stack.map((t: string) => (
                  <span class="text-xs text-navy-400 dark:text-navy-500">{t}</span>
                ))}
              </div>
            </div>
            {sw.github && !sw.github.startsWith('[') && (
              <a href={sw.github} target="_blank" rel="noopener" aria-label={`${sw.name} on GitHub`} class="shrink-0 icon-link text-lg mt-0.5">
                <i class="fa-brands fa-github"></i>
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

  </div>

</PageLayout>
